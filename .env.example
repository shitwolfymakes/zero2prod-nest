# Copy to .env and adjust. `scripts/init_db.sh` provisions a matching database.
NODE_ENV=development
PORT=8000
DATABASE_URL=postgres://postgres:password@localhost:5432/newsletter_nest
LOG_LEVEL=info

# Uncomment/adjust to override the pg pool defaults (shown below).
# DATABASE_SSL=false
# DATABASE_POOL_MAX=10
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
